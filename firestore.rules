rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidRoomCode(id) {
      return id is string && id.size() == 4 && id.matches('^[0-9]+$');
    }

    function isValidRoom(data) {
      return data.id is string && data.id.size() == 4
          && data.hostId is string && data.hostId.size() <= 64
          && data.difficulty is string && (data.difficulty == 'easy' || data.difficulty == 'normal' || data.difficulty == 'hard' || data.difficulty == 'nightmare')
          && data.phase is string && (data.phase == 'lobby' || data.phase == 'countdown' || data.phase == 'playing' || data.phase == 'gameover')
          && data.createdAt is int
          && data.missionNames is list && data.missionNames.size() <= 25
          && data.players is map;
    }

    // Rooms collection rules
    match /rooms/{roomId} {
      allow get, list: if isValidRoomCode(roomId);
      allow create: if isValidRoomCode(roomId) && isValidRoom(request.resource.data);
      allow update: if isValidRoomCode(roomId) && isValidRoom(request.resource.data) 
                    && request.resource.data.id == resource.data.id 
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isValidRoomCode(roomId);
    }
  }
}
